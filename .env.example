# Database
DATABASE_URL="postgresql://user:password@localhost:5432/productlobby?schema=public"

# Durable rate limiting (Upstash Redis via REST — optional; falls back to
# in-memory when unset, which is NOT distributed across serverless instances).
# Provision via Vercel Marketplace (Upstash) — it sets KV_REST_API_* for you.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
# Or raw Upstash naming (either pair works):
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Apple OAuth (id_token verified against Apple JWKS; aud must match APPLE_CLIENT_ID)
APPLE_CLIENT_ID="com.yourcompany.productlobby"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Postmark)
POSTMARK_SERVER_TOKEN="your-postmark-server-token"
EMAIL_FROM="ProductLobby <noreply@productlobby.com>"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Analytics
SENTRY_DSN=""
POSTHOG_KEY=""

# Platform Configuration
PLATFORM_FEE_PERCENT="0.03"
CREATOR_SHARE_PERCENT="0.10"
